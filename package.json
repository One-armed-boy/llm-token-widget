{
  "name": "llm-token-widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify": "node scripts/docs-check.mjs && npm test && npm run test:providers && npm run e2e:mock && npm run snapshot:audit",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "test:providers": "node --test \"tests/provider-adapter.test.mjs\" \"tests/openai-usage-parser.test.mjs\" \"tests/anthropic-usage-parser.test.mjs\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=80 --test-coverage-functions=90 \"tests/**/*.test.mjs\"",
    "docs-check": "node scripts/docs-check.mjs",
    "e2e:mock": "node scripts/e2e-mock.mjs",
    "e2e:openai": "node scripts/e2e-openai.mjs",
    "e2e:anthropic": "node scripts/e2e-anthropic.mjs",
    "e2e:openai:dry-run": "node scripts/e2e-openai-dry-run.mjs",
    "e2e:anthropic:dry-run": "node scripts/e2e-anthropic-dry-run.mjs",
    "snapshot:audit": "node scripts/snapshot-audit.mjs"
  },
  "engines": {
    "node": ">=22"
  }
}
